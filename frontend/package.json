{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-reset.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "i18n:merge-shell": "node scripts/merge-shell-i18n.mjs",
    "i18n:merge-pwa-page": "node scripts/merge-pwa-page-i18n.mjs",
    "i18n:merge-public-flows": "node scripts/merge-public-flows-i18n.mjs",
    "i18n:merge-phase3": "node scripts/merge-phase3-i18n.mjs",
    "i18n:sync-phase3-packs": "node scripts/sync-phase3-pack-files.mjs",
    "i18n:phase3": "npm run i18n:sync-phase3-packs && npm run i18n:merge-phase3 && npm run i18n:verify-locale-parity",
    "i18n:generate-risk-scoring": "node scripts/generate-risk-scoring-messages.mjs",
    "i18n:translate-risk-scoring": "node scripts/translate-risk-scoring-packs.mjs",
    "i18n:translate-risk-scoring:resume": "node scripts/translate-risk-scoring-packs.mjs --resume",
    "i18n:translate-phase3": "node scripts/translate-risk-scoring-packs.mjs --pack=phase3",
    "i18n:translate-phase3:resume": "node scripts/translate-risk-scoring-packs.mjs --pack=phase3 --resume",
    "i18n:phase3:complete": "node scripts/translate-risk-scoring-packs.mjs --pack=phase3 --resume && npm run i18n:merge-phase3 && npm run i18n:verify-locale-parity",
    "i18n:translate-messages": "node scripts/translate-risk-scoring-packs.mjs --pack=messages",
    "i18n:translate-messages:resume": "node scripts/translate-risk-scoring-packs.mjs --pack=messages --resume",
    "i18n:translate-messages:force": "node scripts/translate-risk-scoring-packs.mjs --pack=messages --force",
    "i18n:merge-risk-scoring": "node scripts/merge-risk-scoring-i18n.mjs",
    "i18n:verify-locale-parity": "node scripts/i18n-verify-locale-parity.mjs",
    "i18n:phase0-inventory": "node scripts/i18n-phase0-inventory.mjs",
    "i18n:phase0": "npm run i18n:verify-locale-parity && npm run i18n:phase0-inventory",
    "i18n:phase1-bootstrap-locales": "node scripts/i18n-phase1-sync-bootstrap-locales.mjs",
    "i18n:phase2-bootstrap-locales": "node scripts/i18n-phase2-sync-bootstrap-locales.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tiptap/extension-color": "^3.22.2",
    "@tiptap/extension-highlight": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/extension-text-align": "^3.22.2",
    "@tiptap/extension-text-style": "^3.22.2",
    "@tiptap/extension-underline": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "openai": "^6.34.0",
    "papaparse": "^5.5.3",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "signature_pad": "^5.1.3",
    "three": "^0.183.2",
    "web-ifc-three": "^0.0.126",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "jsonrepair": "^3.14.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
