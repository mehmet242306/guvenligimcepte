# Production canonical (www istemciler PKCE icin hala /auth/* uzerinde kalir; diger yollar apex'e 308)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Shown on OAuth buttons and marketing copy (Google consent screen name is configured in Google Cloud Console)
NEXT_PUBLIC_BRAND_NAME=RiskNova
# Platform admin bos lead CTA mailto (varsayilan support@getrisknova.com)
# NEXT_PUBLIC_SUPPORT_EMAIL=support@getrisknova.com

BACKEND_API_URL=http://127.0.0.1:8000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public "Demo Talep Et" ve /api/contact/demo-request. false = UI ve API kapalı (admin demo-builder kalır).
# NEXT_PUBLIC_DEMO_PUBLIC_ENABLED=false

# Mobil OAuth ayıklama: 1 ise [social-login] redirectTo URL konsola yazılır.
# NEXT_PUBLIC_AUTH_DEBUG=1

# Optional in local development
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@example.com

# Paddle Billing (self-service individual plans only)
# Faz 2 prod kontrol: Vercel'de asagidaki degerler ile Supabase subscription_plans
# (paddle_price_id_monthly / paddle_price_id_yearly) ve Paddle dashboard price ID'leri birebir ayni olmali.
# Webhook URL (Paddle dashboard): https://<domain>/api/billing/webhook
#
# PADDLE_ENV=sandbox
# PADDLE_API_KEY=pdl_sdbx_apikey_...   # veya pdl_live_apikey_... (Bearer yazmayin)
# PADDLE_WEBHOOK_SECRET=
# PADDLE_CHECKOUT_URL=https://www.getrisknova.com/pricing
# PADDLE_PRICE_STARTER_MONTHLY=pri_...
# PADDLE_PRICE_STARTER_YEARLY=pri_...
# PADDLE_PRICE_PLUS_MONTHLY=pri_...
# PADDLE_PRICE_PLUS_YEARLY=pri_...
# PADDLE_PRICE_PROFESSIONAL_99_MONTHLY=pri_...
# PADDLE_PRICE_PROFESSIONAL_99_YEARLY=pri_...
# PADDLE_PRICE_PROFESSIONAL_149_MONTHLY=pri_...
# PADDLE_PRICE_PROFESSIONAL_149_YEARLY=pri_...
# PADDLE_PRICE_PROFESSIONAL_199_MONTHLY=pri_...
# PADDLE_PRICE_PROFESSIONAL_199_YEARLY=pri_...
