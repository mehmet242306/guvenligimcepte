import "jsr:@supabase/functions-js/edge-runtime.d.ts";
import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

const corsHeaders = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Headers": "authorization, x-client-info, apikey, content-type",
};
const ANTHROPIC_API_URL = "https://api.anthropic.com/v1/messages";

// ===== TURKISH SUFFIX STRIPPER =====
const TR_SUFFIXES = [
  "lerimizin", "larimizin", "lerimize", "larimiza",
  "lerinin", "larinin", "imizin", "\u0131m\u0131z\u0131n",
  "inizin", "\u00fcn\u00fcz\u00fcn",
  "lerin", "lar\u0131n", "lere", "lara", "leri", "lar\u0131",
  "inin", "\u0131n\u0131n", "\u00fcn\u00fcn", "unun",
  "imiz", "\u0131m\u0131z", "iniz", "\u0131n\u0131z",
  "ler", "lar", "den", "dan", "ten", "tan",
  "de", "da", "te", "ta",
  "in", "\u0131n", "un", "\u00fcn",
  "ne", "na", "ni", "n\u0131", "nu", "n\u00fc",
  "yi", "y\u0131", "yu", "y\u00fc",
  "si", "s\u0131", "su", "s\u00fc",
  "dir", "d\u0131r", "dur", "d\u00fcr",
  "mi", "m\u0131", "mu", "m\u00fc",
];

function turkishStem(word: string): string {
  let w = word.toLowerCase().replace(/[.,;:!?()]/g, "");
  if (w.length < 4) return w;
  for (const suffix of TR_SUFFIXES) {
    if (w.length > suffix.length + 2 && w.endsWith(suffix)) return w.substring(0, w.length - suffix.length);
  }
  return w;
}

// ===== ISG SYNONYM DICTIONARY =====
const ISG_SYNONYMS: Record<string, string[]> = {
  "d\u00f6ner": ["dairesel", "helezon", "spiral"],
  "dairesel": ["d\u00f6ner", "helezon"],
  "merdiven": ["ka\u00e7\u0131\u015f", "tahliye", "\u00e7\u0131k\u0131\u015f"],
  "kkd": ["koruyucu", "donan\u0131m"],
  "yang\u0131n": ["ka\u00e7\u0131\u015f", "tahliye", "s\u00f6nd\u00fcrme"],
  "ka\u00e7\u0131\u015f": ["tahliye", "\u00e7\u0131k\u0131\u015f"],
  "geni\u015flik": ["geni\u015fli\u011fi", "en"],
  "y\u00fckseklik": ["y\u00fcksekli\u011fi", "irtifa", "kot"],
  "sprinkler": ["ya\u011fmurlama"],
  "ya\u011fmurlama": ["sprinkler"],
  "hidrant": ["yang\u0131n muslu\u011fu"],
  "bodrum": ["zemin alt\u0131"],
  "duman": ["tahliye", "kontrol"],
  "patlay\u0131c\u0131": ["parlay\u0131c\u0131", "yan\u0131c\u0131"],
  "kimyasal": ["zehirli", "tehlikeli"],
  "risk": ["tehlike", "de\u011ferlendirme"],
  "kaza": ["yaralanma", "\u00f6l\u00fcm"],
  "e\u011fitim": ["\u00f6\u011fretim", "seminer"],
};

function buildSearchTerms(query: string): string[] {
  const rawWords = query.toLowerCase().replace(/[.,;:!?()\d]/g, " ").split(/\s+/).filter(w => w.length > 2);
  const stemmed = rawWords.map(turkishStem).filter(w => w.length > 2);
  const synonyms: string[] = [];
  for (const stem of stemmed) {
    for (const [key, syns] of Object.entries(ISG_SYNONYMS)) {
      if (stem === key || stem.includes(key) || key.includes(stem)) synonyms.push(...syns);
    }
  }
  const all = [...new Set([...synonyms, ...stemmed])];
  const stopWords = new Set(["bir", "bu", "ile", "var", "olup", "olan", "gibi", "daha", "acaba", "uygun", "merak"]);
  return all.filter(t => !stopWords.has(t) && t.length > 2).slice(0, 20);
}

// ===== REGION-BASED SYSTEM PROMPTS =====
const LANG_NAMES: Record<string, string> = {
  tr: "Turkish", en: "English", ar: "Arabic", ru: "Russian",
  es: "Spanish", zh: "Chinese", ja: "Japanese", de: "German", fr: "French", hi: "Hindi",
};

function getSystemPrompt(region: string, locale: string): string {
  const langName = LANG_NAMES[locale] || "English";

  if (region === "TR") {
    return `Sen RiskNova platformunun ISG uzman asistanisin.

KRITIK KURALLAR:
1. Yanitlarini Turkce ver.
2. Sana verilen TUM dokumanlari dikkatle incele.
3. Soruyla ilgili TUM maddeleri referans goster.
4. Her referansta dogrudan dokumandan alinti yap.
5. Farkli maddeler farkli acilardan ayni konuya deginiyor olabilir - hepsini belirt.
6. "Mevcut binalar" icin ayri maddeler varsa bunlari da mutlaka belirt.
7. ISG uzmanlarina hitap ediyorsun - teknik ve kesin bilgi ver.
8. Somut rakamlar ver.

YANIT FORMATI:
- Sorunun kisa ozeti
- ILGILI TUM mevzuat maddeleri
- Degerlendirme ve sonuc
- Pratik oneriler

DOKUMAN URETIMI:
<<<DOCUMENT>>>
title: Baslik
type: docx|pptx
---
(icerik)
<<<\/DOCUMENT>>>`;
  }

  // NON-TR regions: general OHS, respond in user's language
  return `You are RiskNova's OHS (Occupational Health & Safety) expert assistant.

CRITICAL RULES:
1. ALWAYS respond in ${langName}.
2. You are an international OHS expert.
3. Reference international standards: ISO 45001, ILO conventions, OSHA standards, EU Framework Directive 89/391/EEC.
4. Provide practical, actionable advice.
5. When specific country regulations are needed, mention that local regulations should be consulted.
6. Be technical - you are addressing OHS professionals.
7. Give concrete numbers and thresholds where applicable.

RESPONSE FORMAT:
- Brief summary of the question
- Relevant international standards and best practices
- Assessment and conclusion
- Practical recommendations

DOCUMENT GENERATION:
<<<DOCUMENT>>>
title: Title
type: docx|pptx
---
(content in ${langName})
<<<\/DOCUMENT>>>`;
}

interface RequestBody {
  query: string;
  user_id: string;
  organization_id?: string;
  region?: string;
  locale?: string;
  history?: { role: string; content: string }[];
}

Deno.serve(async (req: Request) => {
  if (req.method === "OPTIONS") return new Response("ok", { headers: corsHeaders });

  try {
    const anthropicKey = Deno.env.get("ANTHROPIC_API_KEY");
    if (!anthropicKey) return jsonResp({ error: "ANTHROPIC_API_KEY not configured" }, 500);

    const supabase = createClient(Deno.env.get("SUPABASE_URL") ?? "", Deno.env.get("SUPABASE_SERVICE_ROLE_KEY") ?? "");
    const body: RequestBody = await req.json();
    const { query, user_id, organization_id, region = "TR", locale = "tr", history = [] } = body;
    if (!query || !user_id) return jsonResp({ error: "query and user_id required" }, 400);

    const isTR = region === "TR";
    console.log(`Region: ${region}, Locale: ${locale}, TR mode: ${isTR}`);

    // ===== RAG SEARCH (only for TR region) =====
    let uniqueChunks: any[] = [];

    if (isTR) {
      const searchTerms = buildSearchTerms(query);
      console.log("Search terms:", searchTerms.join(", "));

      const { data: rpcResults } = await supabase.rpc("search_legal_chunks_v2", {
        search_terms: searchTerms, result_limit: 15,
      });
      let chunks: any[] = rpcResults || [];

      // ILIKE fallback
      const ilike = ["dairesel merdiven", "d\u00f6ner merdiven", "merdiven%geni\u015f", "ka\u00e7\u0131\u015f%geni\u015f"];
      for (const phrase of ilike) {
        const { data } = await supabase.from("legal_chunks")
          .select("id, article_number, article_title, content, document_id, legal_documents!inner(title, doc_type, doc_number)")
          .ilike("content", `%${phrase}%`).limit(3);
        if (data) {
          for (const d of data) {
            chunks.push({
              chunk_id: d.id, document_id: d.document_id,
              doc_title: (d.legal_documents as any)?.title || "",
              article_number: d.article_number, article_title: d.article_title,
              content: d.content, rank: 0,
            });
          }
        }
      }

      const seen = new Set<string>();
      uniqueChunks = chunks.filter((c: any) => {
        const key = `${c.doc_title || ""}:${c.article_number}`;
        if (seen.has(key)) return false;
        seen.add(key); return true;
      }).slice(0, 15);
      console.log(`RAG: ${uniqueChunks.length} chunks`);
    }

    // ===== BUILD REQUEST =====
    const userContent: any[] = [];

    // Add legal documents (only for TR)
    for (const c of uniqueChunks) {
      const title = `${c.doc_title || "Mevzuat"} - ${c.article_number || ""}`;
      if ((c.content || "").length > 20) {
        userContent.push({
          type: "document",
          source: { type: "text", media_type: "text/plain", data: c.content },
          title: title.substring(0, 200),
          context: `Madde: ${c.article_number || "-"}`,
          citations: { enabled: true },
        });
      }
    }
    userContent.push({ type: "text", text: query });

    const messages: any[] = [];
    for (const h of history.slice(-10)) messages.push({ role: h.role, content: h.content });
    messages.push({ role: "user", content: userContent });

    // ===== CALL CLAUDE =====
    const systemPrompt = getSystemPrompt(region, locale);
    const claudeResp = await fetch(ANTHROPIC_API_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json", "x-api-key": anthropicKey, "anthropic-version": "2023-06-01" },
      body: JSON.stringify({ model: "claude-sonnet-4-20250514", max_tokens: 8192, system: systemPrompt, messages }),
    });

    if (!claudeResp.ok) {
      const err = await claudeResp.text();
      return jsonResp({ error: "AI yanit veremedi", details: err }, 502);
    }

    const claudeData = await claudeResp.json();
    const tokens = (claudeData.usage?.input_tokens || 0) + (claudeData.usage?.output_tokens || 0);

    // Parse response + citations
    let fullText = "";
    const citations: any[] = [];
    for (const block of (claudeData.content || [])) {
      if (block.type === "text") {
        fullText += block.text;
        for (const cite of (block.citations || [])) {
          const chunk = cite.document_index < uniqueChunks.length ? uniqueChunks[cite.document_index] : null;
          citations.push({ cited_text: cite.cited_text || "", document_title: cite.document_title || chunk?.doc_title || "", article_number: chunk?.article_number || "" });
        }
      }
    }

    const docBlocks: any[] = [];
    const re = /<<<DOCUMENT>>>\n?title:\s*(.+)\n?type:\s*(docx|pptx)\n?---\n([\s\S]*?)<<<\/DOCUMENT>>>/g;
    let m;
    while ((m = re.exec(fullText)) !== null) docBlocks.push({ title: m[1].trim(), type: m[2].trim(), content: m[3].trim() });
    const display = fullText.replace(/<<<DOCUMENT>>>[\s\S]*?<<<\/DOCUMENT>>>/g, "").trim();

    const srcMap = new Map<string, any>();
    for (const c of citations) {
      const k = `${c.document_title}:${c.article_number}`;
      if (!srcMap.has(k)) srcMap.set(k, { doc_title: c.document_title, doc_type: "", doc_number: "", article_number: c.article_number, article_title: "" });
    }
    const sources = Array.from(srcMap.values());

    const { data: saved } = await supabase.from("solution_queries").insert({
      user_id, organization_id: organization_id || null, query_text: query, ai_response: display,
      response_metadata: { model: "claude-sonnet-4-20250514", region, locale, sources_count: sources.length, citations_count: citations.length, chunks_found: uniqueChunks.length, documents_generated: docBlocks.length },
      sources_used: sources, response_tokens: tokens,
    }).select("id").single();

    return jsonResp({
      response: display, query_id: saved?.id || null, sources,
      citations: citations.map(c => ({ cited_text: c.cited_text, document_title: c.document_title, article_number: c.article_number })),
      tokens_used: tokens, documents: docBlocks,
    });
  } catch (error) {
    console.error("Error:", error);
    return jsonResp({ error: error.message || "Hata" }, 500);
  }
});

function jsonResp(data: any, status = 200) {
  return new Response(JSON.stringify(data), { status, headers: { ...corsHeaders, "Content-Type": "application/json" } });
}
